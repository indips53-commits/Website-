<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Warung Bu Sukat - Watulimo</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      background: #f5f5f5;
    }

    header {
      background: url('https://source.unsplash.com/800x400/?indonesian-food') center/cover;
      color: white;
      text-align: center;
      padding: 60px 20px;
    }

    header h1 {
      margin: 0;
      font-size: 32px;
    }

    .container {
      padding: 20px;
    }

    .menu {
      background: white;
      border-radius: 10px;
      margin-bottom: 15px;
      overflow: hidden;
      box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    .menu img {
      width: 100%;
      height: 150px;
      object-fit: cover;
    }

    .menu-content {
      padding: 15px;
    }

    button {
      background: #25D366;
      color: white;
      border: none;
      padding: 10px;
      border-radius: 5px;
      cursor: pointer;
    }

    .info {
      background: white;
      padding: 15px;
      border-radius: 10px;
      margin-top: 20px;
    }

    iframe {
      width: 100%;
      border: 0;
      border-radius: 10px;
      margin-top: 10px;
    }
  </style>
</head>

<body>

<header>
  <h1>Warung Bu Sukat</h1>
  <p>Sarapan Enak Khas Watulimo</p>
</header>

<div class="container">

  <div class="menu">
    <img src="https://source.unsplash.com/400x300/?pecel" alt="">
    <div class="menu-content">
      <h3>Nasi Pecel</h3>
      <p>Harga: Rp 7.000</p>
      <button onclick="pesan('Nasi Pecel')">Pesan via WhatsApp</button>
    </div>
  </div>

  <div class="menu">
    <img src="https://source.unsplash.com/400x300/?lontong" alt="">
    <div class="menu-content">
      <h3>Lontong Sayur</h3>
      <p>Harga: Rp 8.000</p>
      <button onclick="pesan('Lontong Sayur')">Pesan via WhatsApp</button>
    </div>
  </div>

  <div class="menu">
    <img src="https://source.unsplash.com/400x300/?nasi-kuning" alt="">
    <div class="menu-content">
      <h3>Nasi Kuning</h3>
      <p>Harga: Rp 10.000</p>
      <button onclick="pesan('Nasi Kuning')">Pesan via WhatsApp</button>
    </div>
  </div>

  <div class="info">
    <h3>Jam Buka</h3>
    <p>Setiap hari: 05.30 - 10.00 WIB</p>

    <h3>Lokasi</h3>
    <p>Watulimo, Trenggalek</p>

    <iframe 
      src="https://maps.google.com/maps?q=Watulimo%20Trenggalek&t=&z=13&ie=UTF8&iwloc=&output=embed"
      height="200">
    </iframe>
  </div>

</div>

<script>
function pesan(menu) {
  var nomor = "6281234567890"; // GANTI nomor WA
  var pesan = "Halo Bu Sukat, saya mau pesan " + menu;
  var url = "https://wa.me/" + nomor + "?text=" + encodeURIComponent(pesan);
  window.open(url, '_blank');
}
</script>

</body>
</html>